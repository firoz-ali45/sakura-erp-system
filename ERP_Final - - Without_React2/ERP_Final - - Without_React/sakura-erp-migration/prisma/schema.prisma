// Sakura ERP Database Schema
// Prisma schema for PostgreSQL
// This schema mirrors the existing database structure exactly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTHENTICATION ====================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  passwordHash  String?   @map("password_hash")
  phone         String?
  role          String    @default("user") // admin, user, manager, viewer
  status        String    @default("inactive") // active, inactive, suspended
  permissions   Json      @default("{\"accountsPayable\": false, \"forecasting\": false, \"warehouse\": false, \"userManagement\": false, \"reports\": false, \"settings\": false}")
  notes         String?
  profilePhotoUrl String? @map("profile_photo_url")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLogin     DateTime? @map("last_login") @db.Timestamptz(6)
  lastActivity  DateTime? @default(now()) @map("last_activity") @db.Timestamptz(6)
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz(6)

  // Relations
  approvedByUser User?     @relation("UserApprovals", fields: [approvedBy], references: [id])
  approvedUsers  User[]    @relation("UserApprovals")
  auditLogs      AuditLog[]
  activities     UserActivity[]
  sessions       UserSession[]
  notifications  Notification[]
  reports        Report[]
  apiKeys        ApiKey[]
  createdBackups BackupLog[] @relation("UserBackups")
  purchaseOrders  PurchaseOrder[] @relation("UserPurchaseOrders")
  transferOrders  TransferOrder[] @relation("UserTransferOrders")
  inventoryCounts InventoryCount[] @relation("UserInventoryCounts")
  productions     Production[] @relation("UserProductions")

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

// ==================== INVENTORY MODULE ====================

model InventoryCategory {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  nameLocalized String?  @map("name_localized")
  reference     String?
  deleted       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  items         InventoryItem[]

  @@index([name])
  @@index([deleted])
  @@map("inventory_categories")
}

model InventoryItem {
  id                      String   @id @default(uuid()) @db.Uuid
  inventoryItemId         String?  @unique @map("inventory_item_id")
  name                    String
  nameLocalized           String?  @map("name_localized")
  sku                     String   @unique
  category                String?  @default("Uncategorized")
  categoryId              String?  @map("category_id") @db.Uuid
  storageUnit             String   @map("storage_unit")
  ingredientUnit           String   @map("ingredient_unit")
  storageToIngredient      Decimal  @default(1) @map("storage_to_ingredient") @db.Decimal(10, 2)
  costingMethod           String   @default("From Transactions") @map("costing_method")
  cost                    Decimal  @default(0) @db.Decimal(10, 2)
  barcode                 String?
  minLevel                String?  @map("min_level")
  maxLevel                String?  @map("max_level")
  parLevel                String?  @map("par_level")
  tags                    Json     @default("[]")
  ingredients             Json     @default("[]")
  suppliers               Json     @default("[]")
  deleted                 Boolean  @default(false)
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  categoryRelation InventoryCategory? @relation(fields: [categoryId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  transferOrderItems TransferOrderItem[]
  inventoryCountItems InventoryCountItem[]
  productionItems    ProductionItem[]

  @@index([sku])
  @@index([category])
  @@index([inventoryItemId])
  @@index([deleted])
  @@index([createdAt])
  @@map("inventory_items")
}

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  nameLocalized String?  @map("name_localized")
  email         String?
  phone         String?
  address       String?
  contactPerson String?  @map("contact_person")
  taxId         String?  @map("tax_id")
  paymentTerms  String?  @map("payment_terms")
  notes         String?
  deleted       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([deleted])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String   @id @default(uuid()) @db.Uuid
  poNumber        String   @unique @map("po_number")
  supplierId      String   @map("supplier_id") @db.Uuid
  orderDate       DateTime @map("order_date") @db.Timestamptz(6)
  expectedDate    DateTime? @map("expected_date") @db.Timestamptz(6)
  status          String   @default("pending") // pending, received, partial, completed, cancelled
  totalAmount     Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  vatAmount       Decimal  @default(0) @map("vat_amount") @db.Decimal(10, 2)
  notes           String?
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  createdByUser   User?    @relation("UserPurchaseOrders", fields: [createdBy], references: [id])

  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  vatRate         Decimal  @default(0) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount       Decimal  @default(0) @map("vat_amount") @db.Decimal(10, 2)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(10, 2)
  receivedQuantity Decimal @default(0) @map("received_quantity") @db.Decimal(10, 2)
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item            InventoryItem @relation(fields: [itemId], references: [id])

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_items")
}

model TransferOrder {
  id              String   @id @default(uuid()) @db.Uuid
  transferNumber  String   @unique @map("transfer_number")
  fromLocation    String   @map("from_location")
  toLocation      String   @map("to_location")
  transferDate    DateTime @map("transfer_date") @db.Timestamptz(6)
  status          String   @default("pending") // pending, in_transit, completed, cancelled
  notes           String?
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  items           TransferOrderItem[]
  createdByUser   User?    @relation("UserTransferOrders", fields: [createdBy], references: [id])

  @@index([transferNumber])
  @@index([status])
  @@index([transferDate])
  @@map("transfer_orders")
}

model TransferOrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  transferOrderId String   @map("transfer_order_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  transferredQuantity Decimal @default(0) @map("transferred_quantity") @db.Decimal(10, 2)
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
  item            InventoryItem @relation(fields: [itemId], references: [id])

  @@index([transferOrderId])
  @@index([itemId])
  @@map("transfer_order_items")
}

model InventoryCount {
  id              String   @id @default(uuid()) @db.Uuid
  countNumber     String   @unique @map("count_number")
  location        String?
  countDate       DateTime @map("count_date") @db.Timestamptz(6)
  status          String   @default("draft") // draft, in_progress, completed, adjusted
  notes           String?
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  items           InventoryCountItem[]
  createdByUser   User?    @relation("UserInventoryCounts", fields: [createdBy], references: [id])

  @@index([countNumber])
  @@index([status])
  @@index([countDate])
  @@map("inventory_counts")
}

model InventoryCountItem {
  id              String   @id @default(uuid()) @db.Uuid
  inventoryCountId String  @map("inventory_count_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  expectedQuantity Decimal @map("expected_quantity") @db.Decimal(10, 2)
  countedQuantity Decimal  @map("counted_quantity") @db.Decimal(10, 2)
  variance        Decimal  @default(0) @db.Decimal(10, 2)
  batchNumber     String?  @map("batch_number")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  inventoryCount  InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  item            InventoryItem @relation(fields: [itemId], references: [id])

  @@index([inventoryCountId])
  @@index([itemId])
  @@map("inventory_count_items")
}

model Production {
  id              String   @id @default(uuid()) @db.Uuid
  productionNumber String  @unique @map("production_number")
  productionDate  DateTime @map("production_date") @db.Timestamptz(6)
  status          String   @default("draft") // draft, in_progress, completed, cancelled
  notes           String?
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  items           ProductionItem[]
  createdByUser   User?    @relation("UserProductions", fields: [createdBy], references: [id])

  @@index([productionNumber])
  @@index([status])
  @@index([productionDate])
  @@map("productions")
}

model ProductionItem {
  id              String   @id @default(uuid()) @db.Uuid
  productionId    String   @map("production_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @map("unit_cost") @db.Decimal(10, 2)
  totalCost       Decimal  @map("total_cost") @db.Decimal(10, 2)
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  production      Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  item            InventoryItem @relation(fields: [itemId], references: [id])

  @@index([productionId])
  @@index([itemId])
  @@map("production_items")
}

// ==================== MANAGE MODULE ====================

model Tag {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique
  color         String?  @default("#6366f1")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([name])
  @@map("tags")
}

// ==================== QUALITY TRACEABILITY ====================

model GrnInspection {
  id              String   @id @default(uuid()) @db.Uuid
  grnNumber       String   @unique @map("grn_number")
  purchaseOrderId String?  @map("purchase_order_id") @db.Uuid
  inspectionDate  DateTime @map("inspection_date") @db.Timestamptz(6)
  status          String   @default("pending") // pending, passed, failed, conditional
  inspectorName   String?  @map("inspector_name")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  items           GrnInspectionItem[]

  @@index([grnNumber])
  @@index([purchaseOrderId])
  @@index([status])
  @@map("grn_inspections")
}

model GrnInspectionItem {
  id              String   @id @default(uuid()) @db.Uuid
  grnInspectionId String   @map("grn_inspection_id") @db.Uuid
  itemId          String   @map("item_id") @db.Uuid
  batchNumber     String?  @map("batch_number")
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(6)
  quantity        Decimal  @db.Decimal(10, 2)
  qualityStatus   String   @map("quality_status") // passed, failed, conditional
  testResults     Json?    @map("test_results")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  grnInspection   GrnInspection @relation(fields: [grnInspectionId], references: [id], onDelete: Cascade)

  @@index([grnInspectionId])
  @@index([itemId])
  @@map("grn_inspection_items")
}

// ==================== REPORTS MODULE ====================

model Report {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  reportName    String   @map("report_name")
  reportType    String   @map("report_type")
  parameters    Json?
  status        String   @default("pending") // pending, processing, completed, failed
  fileUrl       String?  @map("file_url")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz(6)

  // Relations
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

// ==================== AUDIT & SYSTEM ====================

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  action        String   // INSERT, UPDATE, DELETE
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id") @db.Uuid
  oldValues     Json?
  newValues     Json?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserActivity {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  activityType      String   @map("activity_type")
  activityDescription String? @map("activity_description")
  module            String?
  metadata          Json?
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
  @@map("user_activities")
}

model UserSession {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  sessionToken  String   @unique @map("session_token")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  isActive      Boolean  @default(true) @map("is_active")
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActivity  DateTime @default(now()) @map("last_activity") @db.Timestamptz(6)

  // Relations
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionToken])
  @@index([isActive, expiresAt])
  @@map("user_sessions")
}

model Notification {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  title         String
  message       String
  type          String   @default("info") // info, success, warning, error, approval
  isRead        Boolean  @default(false) @map("is_read")
  actionUrl     String?  @map("action_url")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt        DateTime? @map("read_at") @db.Timestamptz(6)

  // Relations
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SystemSetting {
  id            String   @id @default(uuid()) @db.Uuid
  settingKey    String   @unique @map("setting_key")
  settingValue  Json     @map("setting_value")
  description   String?
  updatedBy     String?  @map("updated_by") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([settingKey])
  @@map("system_settings")
}

model ApiKey {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  keyName       String   @map("key_name")
  apiKey        String   @unique
  permissions   Json?
  isActive      Boolean  @default(true) @map("is_active")
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([apiKey])
  @@index([isActive])
  @@map("api_keys")
}

model BackupLog {
  id            String   @id @default(uuid()) @db.Uuid
  backupType    String   @map("backup_type")
  status        String   @default("pending") // pending, in_progress, completed, failed
  filePath      String?  @map("file_path")
  fileSize      BigInt?  @map("file_size")
  errorMessage  String?  @map("error_message")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz(6)

  // Relations
  createdByUser User?    @relation("UserBackups", fields: [createdBy], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("backup_logs")
}

